{
  "name": "falsology",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "generate:claims": "node scripts/generate-claims.mjs",
    "validate:claims": "node scripts/validate-claims.mjs",
    "predev": "npm run generate:claims",
    "dev": "next dev",
    "prebuild": "npm run generate:claims && npm run validate:claims",
    "build": "next build",
    "start": "next start",
    "lint": "npm run generate:claims && eslint .",
    "typecheck": "npm run generate:claims && tsc --noEmit"
  },
  "dependencies": {
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.2",
    "eslint-config-next": "16.2.10",
    "typescript": "5.9.3"
  },
  "overrides": {
    "postcss": "8.5.19"
  }
}

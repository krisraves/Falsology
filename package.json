{
  "name": "falsology",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "prepare:deck": "node scripts/prepare-500-deck.mjs",
    "validate:cases": "npm run prepare:deck && node scripts/validate-detective-cases.mjs",
    "predev": "npm run prepare:deck",
    "dev": "next dev",
    "prebuild": "npm run validate:cases",
    "build": "next build",
    "start": "next start",
    "lint": "npm run validate:cases && eslint .",
    "typecheck": "npm run validate:cases && tsc --noEmit"
  },
  "dependencies": {
    "next": "16.2.10",
    "next-auth": "^5.0.0-beta.31",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.2",
    "eslint-config-next": "16.2.10",
    "typescript": "5.9.3"
  },
  "overrides": {
    "postcss": "8.5.19"
  }
}
